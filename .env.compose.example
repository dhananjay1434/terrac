# P3.1 — copy to `.env` (same dir as docker-compose.yml) and fill in.
# `.env` is gitignored; this example carries placeholders only, never secrets.

# --- Postgres ---
POSTGRES_USER=dmrv
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=dmrv

# --- API secrets (REQUIRED) ---
# Generate FRESH 32-byte base64url values per environment, e.g.:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode().rstrip('='))"
# Rotating DMRV_HMAC_SECRET invalidates verification of already-issued
# lca_signature values — archive the old key before rotating (see server.py).
DMRV_HMAC_SECRET=
DMRV_ADMIN_SECRET=

# Exact browser origin of the portal (never "*" with credentials). Empty = none.
DMRV_ALLOWED_ORIGIN=

# --- Optional ---
LOG_LEVEL=INFO
API_PORT=8001
# Set to 1 only to boot without applying migrations (not for normal use).
DMRV_SKIP_MIGRATIONS=

# --- Observability (P3.4) ---
# Token to scrape GET /metrics; empty keeps the endpoint closed.
DMRV_METRICS_TOKEN=
# Sentry DSN; empty disables it.
DMRV_SENTRY_DSN=
DMRV_SENTRY_TRACES=0.05
DMRV_ENV=compose

# --- MinIO (only used with `--profile storage`, lands in P3.2/P3.3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
