# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Environment files
.env
.env.*
!.env.example
!.env.compose.example
backend/.env

# Local databases & artifacts
*.db
*.sqlite
*.sqlite3
backend/uploads/
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# Dev prompt dumps & throwaway scripts (never ship)
all_user_inputs.txt
longest_msg.txt
*_block.txt

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
*.log
android/hs_err_pid*.log
hs_err_pid*.log

# Android release signing — NEVER commit the keystore or its passwords (P0.1/P0.6)
**/key.properties
!**/key.properties.example
**/*.jks
**/*.keystore

# Demo tooling secrets (P0.3) — the scrubbed demo_tools ships, its live secrets never do
demo_tools/demo_secrets.bat

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

memory/test_credentials.md

# Mobile development
android-sdk/
backend/uploads/

# Session/agent artifacts
.claude/
.baseline_*.txt
backend/pytest_out.txt
