# Database configuration
# Dev: SQLite file in this folder (zero-config, default)
DATABASE_URL=sqlite+aiosqlite:///./dmrv.db
# Prod: PostgreSQL (asyncpg)
# DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/dmrv

# Security
# Required: 32-byte secret for the lca_signature HMAC, base64url encoded.
# Legacy single-key form (exposed internally as key id "k0"). Still fully
# supported; new deploys may instead use the versioned form below.
DMRV_HMAC_SECRET=
# P3.6 versioned HMAC keys (rotation-safe). If set, takes precedence over
# DMRV_HMAC_SECRET. JSON map of id -> secret, plus which id is active for
# signing. Rotate by adding a new id, pointing ACTIVE at it, and KEEPING the old
# id so historical signatures still verify.
#   DMRV_HMAC_KEYS={"k2":"<hex>","k1":"<hex>"}
#   DMRV_HMAC_ACTIVE_KEY=k2
DMRV_HMAC_KEYS=
DMRV_HMAC_ACTIVE_KEY=
# Required: dedicated admin auth secret, distinct from the HMAC pepper above
DMRV_ADMIN_SECRET=

# CORS Configuration
# Must be a single explicit origin (or comma-split list). Must NEVER be * when credentials are enabled.
DMRV_ALLOWED_ORIGIN=https://example.com

# Logging
LOG_LEVEL=INFO

# Migrations
# Set to 1 to skip running migrations on startup (e.g., for tests)
DMRV_SKIP_MIGRATIONS=

# Observability (P3.4)
# Bearer-style token required to scrape GET /metrics. Leave empty to keep the
# endpoint fully closed (a public scrape leaks operational intel).
DMRV_METRICS_TOKEN=
# Sentry error reporting. Empty = disabled (no-op). traces sample rate 0..1.
DMRV_SENTRY_DSN=
DMRV_SENTRY_TRACES=0.05
DMRV_ENV=production

# Media storage (P3.2)
# local (default) | s3. For s3, DMRV_MEDIA_BUCKET is required; set
# DMRV_S3_ENDPOINT for MinIO/GCS-interop (omit for AWS).
DMRV_MEDIA_BACKEND=local
DMRV_MEDIA_BUCKET=
DMRV_S3_ENDPOINT=
DMRV_S3_ACCESS_KEY=
DMRV_S3_SECRET_KEY=
DMRV_S3_REGION=
