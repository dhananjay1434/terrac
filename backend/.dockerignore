# P3.1 — keep the image small and free of dev/runtime state.
# Context root is backend/ (see Dockerfile header), so these paths are
# relative to backend/.
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/

# Local dev database + any WAL/SHM sidecars — never bake data into an image.
dmrv.db
dmrv.db-*
*.db
*.db-*

# Runtime evidence uploads live on a volume/object store, not in the image.
uploads/

# Secrets: config is injected via the environment, never a checked-in .env.
.env
.env.*

# Tests do not run inside the production image.
tests/

# Editor/OS noise.
.mypy_cache/
*.log
